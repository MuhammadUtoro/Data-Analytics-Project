      <aliases enabled='yes' />
      <column caption='Avg Recovery Rate' datatype='real' name='[Calculation_810929427056140289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Recovered]/[Cases])*100' />
      </column>
      <column caption='Cases per Capita' datatype='real' name='[Calculation_810929427057680386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Cases]/[population])*1000' />
      </column>
      <column caption='Death per Capita' datatype='real' name='[Calculation_810929427059466243]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Deaths]/[population])*1000' />
      </column>
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
        <calculation class='tableau' formula='1' />
      </column>
