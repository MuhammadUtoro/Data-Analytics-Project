    <worksheet name='Cases per Capita (HIghest)'>
      <table>
        <view>
          <datasources>
            <datasource caption='covid_19' name='federated.1ub9kdh1dsmw52113m86215dxl6k' />
          </datasources>
          <datasource-dependencies datasource='federated.1ub9kdh1dsmw52113m86215dxl6k'>
            <column caption='Cases per Capita' datatype='real' name='[Calculation_810929427057680386]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Cases]/[population])*1000' />
            </column>
            <column datatype='integer' name='[Cases]' role='measure' type='quantitative' />
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
